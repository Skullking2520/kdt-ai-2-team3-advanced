AI_SERVICE_MODE=mock
HF_SERVING_TYPE=endpoint

HF_TOKEN=

# Used only when HF_SERVING_TYPE=serverless.
HF_SERVERLESS_BASE_URL=https://router.huggingface.co/hf-inference/models

# Used when the encoder runs on HF Inference Endpoint or HF Space API.
ENCODER_ENDPOINT_URL=

# Keep enabled for the current encoder because training used preprocessed text.
ENCODER_PREPROCESS_ENABLED=true

# hf_inputs sends {"inputs": "..."}.
# text_json sends {"text": "..."} for a custom HF Space/FastAPI endpoint.
ENCODER_REQUEST_FORMAT=hf_inputs

# text_generation sends {"inputs": "...", "parameters": {...}} to the
# dedicated/custom decoder endpoint.
# chat_completion is available for HF Inference Providers fallback.
DECODER_API_TYPE=text_generation

# Used only when DECODER_API_TYPE=chat_completion.
DECODER_PROVIDER=featherless-ai

# true means phishing results must call the decoder endpoint.
DECODER_REQUIRED=true

# Used when the decoder runs on a dedicated endpoint or custom URL.
DECODER_ENDPOINT_URL=

ENCODER_MODEL_ID=kdt-2-team4-newbiz/kcelectra-smishing-classifier
ENCODER_MODEL_VERSION=v1.0.0

DECODER_MODEL_ID=Qwen/Qwen3-1.7B
DECODER_MODEL_VERSION=v1.0.0

REQUEST_TIMEOUT_SECONDS=60
HF_MAX_RETRIES=2
HF_RETRY_BACKOFF_SECONDS=0.5
DECODER_MAX_NEW_TOKENS=120
DECODER_TEMPERATURE=0.3
DECODER_ON_NORMAL=false
