# .env를 다음과 같이 작성하라는 의미의 파일, .env는 github에 올리지 않는다.
APP_ENV='development' # development, production

# FE
VITE_SMISHING_HOME_URL=<localhost | your deployed cloud domain>

# BE

MYSQL_ROOT_PASSWORD=
MYSQL_DATABASE=
MYSQL_USER=
MYSQL_PASSWORD=
DATABASE_URL=

# grafana
GF_SECURITY_ADMIN_PASSWORD=<your grafana admin pw>

# ai_service
HF_SMISHING_ENCODER_URL=
HF_TIMEOUT_SECONDS=45
HF_DECODER_MAX_NEW_TOKENS=128
ENCODER_API_KEY=<our huggingface organization api authorized api key>
HF_TOKEN=<decoder api key>
ENCODER_INFERENCE_ENDPOINT=<HF_SMISHING_ENCODER_URL>
DECODER_ENDPOINT_URL=<HF_SMISHING_DECODER_URL>
EXPLAINER_MODEL=Qwen/Qwen3-1.7B

# openai api key (ipynb test용)
OPENAI_API_KEY=<your openapi api key>
