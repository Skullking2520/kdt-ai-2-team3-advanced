# .env를 다음과 같이 작성하라는 의미의 파일, .env는 github에 올리지 않는다.
# 모노리포의 모든 환경 변수 모음

# 공통
APP_ENV='development' # development, production

################# FE
# Mock 사용 여부 (true: Mock 응답, false: 실제 백엔드 호출)
VITE_USE_MOCK=true

# 실제 백엔드 base URL (VITE_USE_MOCK=false 일 때만 사용)
VITE_API_BASE_URL=http://localhost:8000

# HTTP 요청 타임아웃 (ms)
VITE_API_TIMEOUT=10000

# Mock 응답 지연 (ms) — 발표 데모용 (너무 길면 사용자 짜증)
VITE_MOCK_DELAY_MS=400

# 디버그 로그
VITE_DEBUG=true

# 관리자 비밀번호 (AdminContext 로그인용) — prod에서는 반드시 강력한 값으로 설정
# 미설정 시 /admin 로그인 기능 비활성화
VITE_ADMIN_PASSWORD=<AdminContext 로그인용 비밀번호>

################# BE

MYSQL_ROOT_PASSWORD=
MYSQL_DATABASE=
MYSQL_USER=
MYSQL_PASSWORD=
DATABASE_URL=

USE_MOCK_MODEL=true   # 모델 엔드포인트 없이 테스트할 때 true로 설정
USE_MOCK_OCR=true     # PaddleOCR/CLOVA 없이 테스트할 때 true로 설정
USE_CLOVA_ONLY=false  # true: CLOVA만 사용, false: PaddleOCR → 품질 미달 시 CLOVA fallback

# 인코더 (HuggingFace Inference Endpoint)
ENCODER_API_KEY=<HuggingFace API 키 (hf_로 시작)>
ENCODER_INFERENCE_ENDPOINT=<HuggingFace Inference Endpoint URL>
HF_TIMEOUT_SECONDS=30

# 디코더 (Modal LangGraph RAG 서비스)
DECODER_ENDPOINT_URL=<Modal 배포 URL>
HF_DECODER_MAX_NEW_TOKENS=128

# VirusTotal URL 후보 검증 worker
VIRUSTOTAL_API_KEY=<VirusTotal에서 발급받는 일반 api key>
VT_TIMEOUT_SECONDS=15
VT_BATCH_SIZE=100
VT_WORKER_INTERVAL_MINUTES=5
VT_RECHECK_DAYS=7
VT_SUBMITTED_RECHECK_MINUTES=15
VT_ERROR_RETRY_HOURS=6
VT_AUTO_APPROVE_MALICIOUS_COUNT=3
VT_SUBMIT_UNKNOWN_URLS=true
VT_REQUESTS_PER_MINUTE=4
VT_DAILY_REQUEST_LIMIT=400
VT_RATE_LIMIT_RETRY_SECONDS=60
VT_DAILY_LIMIT_RETRY_SECONDS=86400
VT_WORKER_STARTUP_DELAY_SECONDS=15
VT_CANDIDATE_LEASE_MINUTES=30
ADMIN_API_KEY=<URL 후보 검토 API>

# 데이터 수집 파이프라인 (MySQL RDS 접속 정보)
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=

################# 데이터 전처리

# AWS S3 (데이터 파이프라인 VT 결과 저장용)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-northeast-2
S3_BUCKET=

# URLhaus 크롤러 (선택, 없으면 OpenPhish만 사용)
URLHAUS_AUTH_KEY=<URLHAUS_API_KEY>

# Pinecone
PINECONE_API_KEY=<파인콘 api key>
PINECONE_INDEX=<파인콘 index 이름 (예: smishing-cases-v01)>

# grafana
GF_SECURITY_ADMIN_PASSWORD=<your grafana admin pw>

# CLOVA OCR (USE_MOCK_OCR=true 시 불필요, 실제 OCR 사용 시 .env.local에 설정 권장)
CLOVA_OCR_URL=<클로바 ocr 세팅 후 url>
CLOVA_OCR_SECRET=<클로바 ocr secret>

############## ai_service: src(rag)
# langfuse .env key
LANGFUSE_SECRET_KEY=<내 프로젝트의 인증 암호이며 public key와 한 쌍>
LANGFUSE_PUBLIC_KEY=<sdk에서 데이터를 안전하게 수집할 때 사용되는 키>
LANGFUSE_BASE_URL=<랭퓨즈 클라우드의 기본 리전 URL>

# modal에서 참조할 vllm으로 배포한 모델 url (vllm은 openai api 규격을 따름, 주의: <endpoint>/v1형식임!)
OPENAI_API_BASE=https://<your-username>--qwen-vllm-service-vllmserver-api.modal.run/v1
VLLM_MODEL_NAME=<Modal 배포환경에서 참조할 모델명: <사용자명>/<모델명> 형식>

# openai api key (test용)
OPENAI_API_KEY=<openai api key>

# 파인콘 (프로덕션 환경)
PINECONE_API_KEY=<파인콘 api key>
PINECONE_INDEX=<파인콘 index 저장공간>

# CHROMA DB (로컬 환경)
CHROMA_DB_DIR="./data/chroma_db"
CHROMA_COLLECTION_NAME="zeroday_smishing_patterns"

# 임베딩 설정 (예: "openai", "ollama", "huggingface")
EMBEDDING_PROVIDER="huggingface" # 임베딩 모델 출처 (운영용)
EMBEDDING_MODEL_NAME="jhgan/ko-sroberta-multitask" # 임베딩 모델 (운영용)

# ollama 설정 (운영용 LLM)
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL_NAME=<ollama에서 돌아가고 있는 모델 이름, hf.<허깅페이스 사용자명>/<모델명>>
OLLAMA_NUM_CTX=8192 # AI가 기억할 수 있는 대화/문서의 길이(8192면 한글 약 4,000자 이상), context window, 하드웨어 사양 고려
OLLAMA_NUM_PREDICT=1024 # 한 번에 답변할 수 있는 최대 분량 (기본: -1 무제한)

# 평가 LLM 설정 (ragas 메트릭 계산용)
EVALUATOR_LLM_PROVIDER="openai"  # openai 또는 ollama
EVALUATOR_MODEL_NAME="gpt-4o-mini"  # openai: gpt-4o-mini, ollama: 모델명
EVALUATOR_TEMPERATURE=0.0

# 평가 배치 처리 설정
EVALUATION_BATCH_SIZE=10  # 한 번에 평가할 데이터 수
EVALUATION_MAX_CONCURRENT_REQUESTS=3  # 동시 요청 수
EVALUATION_REQUEST_TIMEOUT=60  # 단일 요청 타임아웃(초)
EVALUATION_RETRY_COUNT=2  # 실패 시 재시도 횟수
EVALUATION_RETRY_DELAY=5  # 재시도 대기 시간(초)
EVALUATION_MAX_ITEMS=0  # 0 = 제한 없음, N > 0 = N개까지만 평가
EVALUATION_COST_LIMIT_DOLLARS=0.0  # 0.0 = 제한 없음, N > 0 = N달러 제한
EVALUATION_SKIP_ON_ERROR=true  # true = 오류 발생 시 스킵하고 계속, false = 중단

# hf_hub
HF_XET_HIGH_PERFORMANCE=1
