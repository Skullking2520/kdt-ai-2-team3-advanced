# .env 예시 — NewBiz Shield

# Mock 사용 여부 (true: Mock 응답, false: 실제 백엔드 호출)
VITE_USE_MOCK=true

# 실제 백엔드 base URL (VITE_USE_MOCK=false 일 때만 사용)
VITE_API_BASE_URL=http://localhost:8000

# HTTP 요청 타임아웃 (ms)
VITE_API_TIMEOUT=10000

# Mock 응답 지연 (ms) — 발표 데모용 (너무 길면 사용자 짜증)
VITE_MOCK_DELAY_MS=400

# 디버그 로그
VITE_DEBUG=true

# 관리자 화면은 개발용 보조 기능입니다. VITE_ 변수는 브라우저 번들에 포함되므로
# 실제 비밀번호나 운영용 인증 정보를 넣지 않습니다.
# 미설정 시 /admin 로그인 기능이 비활성화됩니다.
VITE_ADMIN_PASSWORD=<development-only-password>
